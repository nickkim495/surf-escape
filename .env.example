# Amadeus Self-Service (https://developers.amadeus.com/register)
# Create an app → copy API Key & API Secret.
#
# Test / sandbox (default host) — use keys from the "Test" environment in the dashboard:
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
# Optional: defaults to https://test.api.amadeus.com
# AMADEUS_API_BASE=https://test.api.amadeus.com
#
# Production — use keys from the "Production" environment and set:
# AMADEUS_API_BASE=https://api.amadeus.com
